generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  role          Role          @default(USER)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  opportunities Opportunity[]
  comments      Comment[]
  documents     Document[]
}

enum Role {
  ADMIN
  USER
}

model Opportunity {
  id          String            @id @default(cuid())
  internalId  String?           // Our internal reference (e.g. OPP-2024-001)
  title       String
  customer    String
  reference   String?           // Customer / RFQ reference number
  rfqDate     DateTime?         // Date the RFQ was received
  product     String?           // One-line product/service description
  status        OpportunityStatus @default(NEW)
  waitingOn     WaitingOn         @default(INTERNAL)
  quoteSentDate      DateTime?         // Date the quote was shared with the customer
  elRequestedDate    DateTime?         // Date the EL was requested (quote accepted)
  elDraftSharedDate  DateTime?         // Date the EL draft was shared with the customer
  elSignedSharedDate DateTime?         // Date the signed EL was shared back
  description        String?           // General notes
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])

  comments    Comment[]
  documents   Document[]
}

enum OpportunityStatus {
  NEW
  RFQ_RECEIVED
  QUOTE_SENT
  EL_REQUEST_RECEIVED
  EL_DRAFT_SHARED
  EL_SIGNED_SHARED
  EL_FULLY_SIGNED
  PRODUCTION
  DELIVERED
  CANCELLED
}

enum WaitingOn {
  INTERNAL
  CUSTOMER
  THIRD_PARTY
  NONE
}

model Comment {
  id            String      @id @default(cuid())
  content       String
  system        Boolean     @default(false) // true = system-generated event
  createdAt     DateTime    @default(now())

  authorId      String?     // null for system events
  author        User?       @relation(fields: [authorId], references: [id])

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Document {
  id           String         @id @default(cuid())
  displayName  String
  filename     String
  originalName String
  mimeType     String
  size         Int
  type         DocumentType   @default(OTHER)
  docStatus    DocumentStatus @default(DRAFT)
  uploadedAt   DateTime       @default(now())

  uploadedById  String
  uploadedBy    User          @relation(fields: [uploadedById], references: [id])

  opportunityId String
  opportunity   Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

enum DocumentType {
  QUOTE
  EL
  OTHER
}

enum DocumentStatus {
  DRAFT
  FINAL
}
