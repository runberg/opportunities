# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=opportunities
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=opportunities

# Admin account — synced on every deploy (change password here to recover access)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Next.js Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_secret
NEXTAUTH_URL=http://localhost

# Set to your internal server hostname/IP when deploying
# NEXTAUTH_URL=http://192.168.1.100

# Telemetry opt-outs — disable anonymous usage stats sent by Next.js and Prisma
NEXT_TELEMETRY_DISABLED=1
PRISMA_TELEMETRY_INFORMATION=""
